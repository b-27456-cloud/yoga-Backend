# ===========================
# YogaFlow Backend — Environment Variables
# ===========================
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control.

# ------- Server -------
NODE_ENV=development
PORT=5000

# ------- MongoDB Atlas -------
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/yogaflow?retryWrites=true&w=majority

# ------- Firebase Admin SDK & Auth -------
# Paste the entire JSON service account key as a single-line string,
# OR set the path to the JSON file via GOOGLE_APPLICATION_CREDENTIALS.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Web API Key for authenticating users via REST API
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# ------- Cloudinary -------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ------- CORS -------
# Comma-separated list of allowed origins (leave empty for * in development)
ALLOWED_ORIGINS=http://localhost:3000

# ------- Sentry (optional — Phase 10) -------
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ------- Logging -------
LOG_LEVEL=debug
